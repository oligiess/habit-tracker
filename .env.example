# Copy this file to .env and fill in your real Supabase connection string.
# Get it from: Supabase dashboard > Project Settings > Database > Connection string
# (URI tab, "Direct connection" option, not the Transaction pooler).
# Note: Supabase sometimes shows "postgres://" — change it to "postgresql://",
# SQLAlchemy no longer accepts the bare "postgres://" alias.
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# Your Supabase project URL, used to fetch its Auth JWKS for verifying
# access tokens (Supabase dashboard > Project Settings > API > Project URL).
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role secret key -- used ONLY server-side, to call Supabase's Admin
# API for account deletion (DELETE /api/account). NEVER expose this to the
# frontend/Vite build. Get it from Supabase dashboard > Project Settings >
# API > Project API keys > service_role (click "Reveal").
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# Optional: comma-separated list of allowed CORS origins for production.
# Leave unset for local dev (defaults to localhost:5500 / 127.0.0.1:5500).
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5500,http://127.0.0.1:5500
ALLOWED_ORIGINS=

# Frontend (Vite) -- same Supabase project URL as above, plus the publishable/
# anon key (safe to expose client-side). Read by src/lib/supabaseClient.ts.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable-key>

